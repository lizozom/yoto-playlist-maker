# Copy to .env and fill in.

# Your own Yoto OAuth *public* client_id, with device authorization enabled.
# Register a client at the Yoto developer dashboard: https://dashboard.yoto.dev/
# (public client → enable device authorization → copy the client_id; you do NOT
# need the client secret for the device flow).
#
# Why this is needed: the client_id that @lizozom/yoto ships with is a shared
# community client that Yoto has disabled — logging in with it fails with
# "Activation Denied". Register your own and put it here.
YOTO_CLIENT_ID=

# For `npm run icons` (AI icon curation): your Anthropic API key.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional. Default audio source: youtube-music (default) or youtube.
# AUDIO_SOURCE=youtube-music

# Optional. Output directory and audio bitrate.
# OUTPUT_DIR=./output
# AUDIO_BITRATE=192
